# ── Secretos y entornos locales ──────────────────────────────
# Nunca subir variables de entorno: pueden contener tokens, claves
# de API o el SERVICE_ROLE_KEY de Supabase.
.env
.env.*
!.env.example

# ── Dependencias ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn-integrity

# ── Build / artefactos ───────────────────────────────────────
dist/
build/
.vite/
.cache/
*.tsbuildinfo

# ── Editor / sistema ─────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Supabase CLI ─────────────────────────────────────────────
supabase/.branches
supabase/.temp
supabase/.env

# ── Coverage / tests ─────────────────────────────────────────
coverage/
.nyc_output/
